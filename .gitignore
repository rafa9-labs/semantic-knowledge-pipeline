# ============================================================
# Python
# ============================================================
# Virtual environment — contains local binaries, never commit this.
# Anyone can recreate it with `python -m venv venv && pip install -r requirements.txt`
venv/
.venv/

# Python bytecode — auto-generated, different per Python version.
# __pycache__ folders appear in every directory with imported .py files.
__pycache__/
*.py[cod]
*$py.class

# Distribution artifacts
dist/
build/
*.egg-info/
*.egg

# ============================================================
# Environment & Secrets
# ============================================================
# .env files contain DATABASE_URLs, API keys, passwords.
# These MUST NEVER be committed to git — that's a security incident.
.env
.env.local
.env.production

# ============================================================
# IDE
# ============================================================
# VS Code settings are personal preferences, not project config.
.vscode/
.idea/

# ============================================================
# OS Files
# ============================================================
# macOS
.DS_Store
# Windows
Thumbs.db
desktop.ini

# ============================================================
# Docker
# ============================================================
# Docker volumes live inside Docker's internal storage, not in our repo.
# We define them in docker-compose.yml, so there's nothing to commit here.

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# Playwright
# ============================================================
# Playwright downloads browser binaries to a local cache.
# These are large (~300MB+) and specific to each OS.
playwright/.local-browsers/